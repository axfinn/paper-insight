# 本地配置示例 - 复制为 local.yaml 后修改

# 代理配置（网络不通时使用）
proxy:
  enabled: false
  http: "http://127.0.0.1:8080"
  https: "http://127.0.0.1:8080"

# Claude API 配置
claude:
  api_key: ""  # 留空则使用 ANTHROPIC_API_KEY 环境变量

# GitHub Token（可选，提高 API 限制）
github:
  token: ""

# 抓取配置
fetch:
  papers_per_industry: 10
  analysis_batch_size: 5
  fetch_interval: 7200  # 秒
  analysis_interval: 1800  # 秒

# 磁盘清理
cleanup:
  papers_days: 7
  github_days: 7
  reports_days: 30
  logs_days: 3
